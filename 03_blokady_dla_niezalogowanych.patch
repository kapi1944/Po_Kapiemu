@@ -0,0 +1,77 @@
+/* Wspólna blokada elementów dostępnych dopiero po zalogowaniu */
+.guest-lock-shell {
+  position: relative;
+  min-width: 0;
+  overflow: hidden;
+}
+
+.guest-lock-shell--project { border-radius: 16px; }
+.guest-lock-shell--content,
+.guest-lock-shell--module { border-radius: 11px; }
+
+.guest-lock-shell__content {
+  height: 100%;
+  filter: blur(4px);
+  opacity: .34;
+  pointer-events: none;
+  user-select: none;
+}
+
+.guest-lock-shell--project .project-card,
+.guest-lock-shell--content .content-card {
+  height: 100%;
+}
+
+.guest-lock-overlay {
+  position: absolute;
+  z-index: 6;
+  inset: 0;
+  display: grid;
+  place-content: center;
+  justify-items: center;
+  gap: 7px;
+  padding: 24px;
+  background: linear-gradient(180deg,color-mix(in srgb,var(--panel) 58%,transparent),color-mix(in srgb,var(--panel) 82%,transparent));
+  color: var(--text);
+  text-align: center;
+  backdrop-filter: blur(2px);
+}
+
+.guest-lock-overlay__icon {
+  display: grid;
+  width: 34px;
+  height: 34px;
+  place-items: center;
+  border: 1px solid color-mix(in srgb,var(--brand) 55%,var(--line));
+  border-radius: 50%;
+  background: var(--brand-subtle);
+  color: var(--brand-strong);
+}
+
+.guest-lock-overlay strong {
+  max-width: 260px;
+  font-size: 12px;
+  line-height: 1.3;
+}
+
+.guest-lock-overlay > span:last-child {
+  max-width: 290px;
+  color: var(--muted-strong);
+  font-size: 10px;
+  line-height: 1.45;
+}
+
+.guest-lock-overlay--compact {
+  gap: 5px;
+  padding: 16px;
+}
+
+.guest-lock-overlay--compact .guest-lock-overlay__icon {
+  width: 30px;
+  height: 30px;
+}
+
+@media (max-width: 700px) {
+  .guest-lock-overlay { padding: 18px; }
+  .guest-lock-overlay > span:last-child { max-width: 240px; }
+}
